# Copy this file to ".env" and fill in your real key.
# Get a key from the Geoscape Developer Portal: https://www.geoscape.com.au/

GEOSCAPE_API_KEY=your-real-key-here

# Groq API key for the photo VLM (vegetation classification). Get one at
# https://console.groq.com. Without it the photo step degrades gracefully:
# every side falls back to the map value (no crash). Model is overridable.
GROQ_API_KEY=your-groq-key-here
# GROQ_VLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Phase 1: persistence + consumer accounts ---------------------------------
# MongoDB Atlas connection. Create a free cluster at
# https://www.mongodb.com/atlas, add a database user + network access, then
# paste the SRV connection string here (it embeds the username/password).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=embercheck

# Secret used to sign auth tokens (wired into fastapi-users in Step 2). Generate
# one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET=change-me-to-a-long-random-secret
ACCESS_TOKEN_LIFETIME_SECONDS=3600
REFRESH_TOKEN_LIFETIME_SECONDS=2592000

# Google OAuth 2.0 web client ID. Must match the frontend
# VITE_GOOGLE_CLIENT_ID value; used server-side to verify Google ID tokens.
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
